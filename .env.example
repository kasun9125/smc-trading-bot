# SMC Trading Bot - Environment Variables
# DO NOT upload the real .env file to GitHub!
# Add these values directly in Railway Variables tab

TELEGRAM_TOKEN=your_bot_token_from_botfather_here
TELEGRAM_CHAT_ID=your_chat_id_from_userinfobot_here

# Optional - customize in Railway Variables
CHECK_INTERVAL=900
SIGNAL_THRESHOLD=65
SIGNAL_COOLDOWN=7200
API_RETRIES=3
API_RETRY_DELAY=5
SENT_CLEANUP_HOURS=24
